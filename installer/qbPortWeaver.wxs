<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

	<Package
	  Name="qbPortWeaver"
	  Manufacturer="@martsg666"
	  Version="$(var.ProductVersion)"
	  UpgradeCode="{6E2B5A1C-4D89-4F3A-B2C7-9A1E8D5F0C3B}"
	  InstallerVersion="500"
	  Scope="perMachine">

		<!-- Major upgrade handling -->
		<MajorUpgrade
		  DowngradeErrorMessage="A newer version of qbPortWeaver is already installed."
		  Schedule="afterInstallInitialize" />

		<MediaTemplate EmbedCab="yes" />

		<!-- ARP metadata -->
		<Icon Id="AppIcon.ico" SourceFile="..\qbPortWeaver.ico" />
		<Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
		<Property Id="ARPHELPLINK" Value="https://github.com/martsg666/qbPortWeaver" />
		<Property Id="ARPNOREPAIR" Value="1" />

		<!-- Detect legacy NSIS install (64-bit) -->
		<Property Id="NSIS_UNINST_EXE_X64">
			<DirectorySearch Id="SearchPF64" Path="[ProgramFiles64Folder]">
				<DirectorySearch Id="SearchQbpw64" Path="qbPortWeaver" Depth="0">
					<FileSearch Name="uninst.exe" />
				</DirectorySearch>
			</DirectorySearch>
		</Property>

		<!-- Detect legacy NSIS install (32-bit) -->
		<Property Id="NSIS_UNINST_EXE_X86">
			<DirectorySearch Id="SearchPF32" Path="[ProgramFilesFolder]">
				<DirectorySearch Id="SearchQbpw32" Path="qbPortWeaver" Depth="0">
					<FileSearch Name="uninst.exe" />
				</DirectorySearch>
			</DirectorySearch>
		</Property>

		<!-- Kill running process (EXECUTE SEQUENCE ONLY to avoid 2732) -->
		<CustomAction Id="CA_KillProcess"
					  ExeCommand="taskkill /F /IM qbPortWeaver.exe"
					  Directory="SystemFolder"
					  Execute="immediate"
					  Return="ignore" />

		<!-- Block install if legacy NSIS found (UI sequence only) -->
		<CustomAction Id="CA_BlockNsis"
					  Error="A legacy version of qbPortWeaver is already installed. Please uninstall it before continuing." />

		<!-- UI Sequence -->
		<InstallUISequence>
			<Custom Action="CA_BlockNsis"
					After="AppSearch"
					Condition="NSIS_UNINST_EXE_X64 OR NSIS_UNINST_EXE_X86" />
		</InstallUISequence>

		<!-- Execute Sequence -->
		<InstallExecuteSequence>
			<Custom Action="CA_KillProcess" Before="InstallInitialize" />
		</InstallExecuteSequence>

		<!-- Minimal UI -->
		<ui:WixUI Id="WixUI_Minimal" />
		<WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

		<!-- Launch checkbox -->
		<Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT"
				  Value="Launch qbPortWeaver" />
		<Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />

		<SetProperty Id="WixShellExecTarget"
					 Value="[INSTALLFOLDER]qbPortWeaver.exe"
					 Sequence="ui"
					 Before="ExecuteAction" />

		<CustomAction Id="CA_LaunchApp"
					  BinaryRef="Wix4UtilCA_X64"
					  DllEntry="WixShellExec"
					  Execute="immediate"
					  Return="ignore"
					  Impersonate="yes" />

		<UI>
			<Publish Dialog="ExitDialog"
					 Control="Finish"
					 Event="DoAction"
					 Value="CA_LaunchApp"
					 Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
		</UI>

		<Feature Id="MainFeature" Level="1">
			<ComponentGroupRef Id="AppComponents" />
			<ComponentGroupRef Id="ShortcutComponents" />
		</Feature>

	</Package>

	<!-- Directory structure -->
	<Fragment>
		<StandardDirectory Id="ProgramFiles64Folder">
			<Directory Id="INSTALLFOLDER" Name="qbPortWeaver" />
		</StandardDirectory>

		<StandardDirectory Id="ProgramMenuFolder">
			<Directory Id="StartMenuShortcutFolder" Name="qbPortWeaver" />
		</StandardDirectory>

		<StandardDirectory Id="DesktopFolder" />
	</Fragment>

	<!-- Application files -->
	<Fragment>

		<ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">

			<Component Id="AppExecutable">
				<File Source="..\bin\Release\net10.0-windows\win-x64\publish\qbPortWeaver.exe"
					  KeyPath="yes" />
			</Component>

			<Component Id="AppReadme">
				<File Source="..\README.md" />
			</Component>

		</ComponentGroup>

		<!-- Shortcuts -->
		<ComponentGroup Id="ShortcutComponents">

			<Component Id="DesktopShortcutComp" Directory="DesktopFolder">
				<Shortcut Id="DesktopShortcut"
						  Name="qbPortWeaver"
						  Target="[INSTALLFOLDER]qbPortWeaver.exe"
						  WorkingDirectory="INSTALLFOLDER" />
				<RegistryValue Root="HKCU"
							   Key="Software\qbPortWeaver"
							   Name="DesktopShortcut"
							   Type="integer"
							   Value="1"
							   KeyPath="yes" />
			</Component>

			<Component Id="StartMenuShortcutComp" Directory="StartMenuShortcutFolder">
				<Shortcut Id="StartMenuShortcut"
						  Name="qbPortWeaver"
						  Target="[INSTALLFOLDER]qbPortWeaver.exe"
						  WorkingDirectory="INSTALLFOLDER" />
				<RemoveFolder Id="RemoveStartMenuFolder"
							  Directory="StartMenuShortcutFolder"
							  On="uninstall" />
				<RegistryValue Root="HKCU"
							   Key="Software\qbPortWeaver"
							   Name="StartMenuShortcut"
							   Type="integer"
							   Value="1"
							   KeyPath="yes" />
			</Component>

		</ComponentGroup>

	</Fragment>

</Wix>
